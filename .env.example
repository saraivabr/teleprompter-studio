# Todas opcionais — o app funciona sem nenhuma delas.

# Provedor OpenRouter: se definida, a geração passa a usar o OpenRouter
# em vez do Claude CLI. Crie a sua em https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Modelo no OpenRouter (padrão: anthropic/claude-opus-4.8)
# Lista: https://openrouter.ai/models
OPENROUTER_MODEL=

# Porta do servidor (padrão: 3939)
PORT=3939

# Modelo usado na geração. Sem definir, usa o padrão do seu Claude Code.
# Ex.: CLAUDE_MODEL=opus
CLAUDE_MODEL=

# Defina para ativar autenticação básica ao expor o app na rede.
# Sem definir, o app fica aberto (uso local).
APP_PASSWORD=
